# Secrets
.env
.mcp.json

# User data (created per-install)
context/memory/*
!context/memory/.gitkeep
projects/*
!projects/.gitkeep
brand_context/*.md

# Installer state
.claude/skills/_catalog/installed.json

# Local settings
.claude/settings.local.json
.claude/hooks_info/ccnotify.db
.claude/hooks_info/ccnotify.log*

# System
.DS_Store
.backup/

# Cron logs
cron/logs/

# Outbox runtime data (config/ is committed as client template)
outbox/actions/pending/*
!outbox/actions/pending/.gitkeep
outbox/actions/processing/*
!outbox/actions/processing/.gitkeep
outbox/actions/completed/*
!outbox/actions/completed/.gitkeep
outbox/actions/failed/*
!outbox/actions/failed/.gitkeep
outbox/inbox/pending/*
!outbox/inbox/pending/.gitkeep
outbox/inbox/processing/*
!outbox/inbox/processing/.gitkeep
outbox/inbox/done/*
!outbox/inbox/done/.gitkeep
outbox/status/*.json
!outbox/status/.gitkeep

# Inbox watcher logs
logs/
